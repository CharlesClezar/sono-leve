{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/server/SonoLeve.Api/SonoLeve.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    }
    // O banco de dev é o Postgres compartilhado do Central (não há mais um
    // container de banco por projeto). Suba-o na pasta do Central antes do F5:
    //   python3 central.py postgres up
  ]
}
