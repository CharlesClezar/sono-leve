# ─── Banco de Dados ───────────────────────────────────────────────────────────
POSTGRES_DB=sono_leve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_PORT=5432

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORTA=5010

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SEGREDO=troque_por_uma_chave_secreta_com_minimo_32_caracteres
JWT_EXPIRACAO_MINUTOS=15
JWT_EXPIRACAO_REFRESH_DIAS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas para o backend (pode deixar em branco se não usar acesso direto à API)
CORS_ORIGENS=http://localhost:3010

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Porta exposta do frontend (o browser acessa esta porta)
FRONTEND_PORTA=3010
# Não é mais necessário NEXT_PUBLIC_API_URL — o frontend usa proxy interno para http://api:8080
