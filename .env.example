# ============================================================
# Sono Leve — variáveis de ambiente
# Copie para .env (cp .env.example .env) e ajuste os valores.
# Quando o projeto é gerenciado pelo Central, as variáveis de
# banco abaixo são preenchidas automaticamente — foque nas demais.
# ============================================================

# ── Banco de dados (gerenciado pelo Central) ──
# Em produção via Central estes valores são reescritos para apontar ao Postgres
# compartilhado. Ajuste-os à mão apenas em uso standalone / desenvolvimento.
POSTGRES_DB=sono_leve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# ── API ──
# Porta da API exposta no host
API_PORTA=5010

# ── Segurança ──
# Segredo de assinatura do JWT (mínimo 32 caracteres)
JWT_SEGREDO=troque_por_uma_chave_secreta_com_minimo_32_caracteres
# Validade do token de acesso, em minutos
JWT_EXPIRACAO_MINUTOS=15
# Validade do refresh token, em dias
JWT_EXPIRACAO_REFRESH_DIAS=7

# ── CORS ──
# URL(s) que acessam a aplicação (origens permitidas), separadas por vírgula
CORS_ORIGENS=http://localhost:3010

# ── Frontend ──
# Porta do frontend exposta no host (é por aqui que o navegador acessa)
FRONTEND_PORTA=3010
